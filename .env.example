# Server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Meta Cloud API
META_ACCESS_TOKEN=           # System user token do Meta Developer Portal
META_PHONE_NUMBER_ID=        # ID do número no painel Meta (não o número em si)
META_BUSINESS_NUMBER=        # Número E.164 que professores vão salvar, ex: +5511940000000
META_WEBHOOK_VERIFY_TOKEN=   # String secreta para validar registro do webhook na Meta

# Admin
ADMIN_TOKEN=changeme-admin

# Gemini
GEMINI_API_KEY=your-gemini-api-key
